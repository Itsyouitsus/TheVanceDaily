[{"platform": "X / Twitter", "handle": "@JDVance", "url": "https://x.com/JDVance/status/2037881016140845525", "icon": "<svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"/></svg>", "text": "Ending the fraud industrial complex is about putting the interests of American citizens first.", "time": "Mar 28, 2026 - 01:14 PM", "timestamp": "Sat Mar 28 13:14:30 +0000 2026", "foot": "@JDVance"}, {"platform": "X / Twitter", "handle": "@JDVance", "url": "https://x.com/JDVance/status/2036560958609354795", "icon": "<svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"/></svg>", "text": "For far too long, illegal alien fraudsters and criminals have been allowed to scam Americans out of their hard-earned tax dollars. That stops now. \n\nColin McDonald will be a key asset to the DOJ and the President&#x27;s War on Fraud.", "time": "Mar 24, 2026 - 09:49 PM", "timestamp": "Tue Mar 24 21:49:04 +0000 2026", "foot": "@JDVance"}, {"platform": "X / Twitter", "handle": "@JDVance", "url": "https://x.com/JDVance/status/2035740580848796156", "icon": "<svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"/></svg>", "text": "\u2068We\u2019ve all seen the chaos unleashed by Democrats at airports across the country. It\u2019s preposterous that Chuck Schumer continues to hold TSA funding hostage.\n\nThankfully, ICE will bring sanity to our airports starting tomorrow, but it\u2019s far past time for Democrats to fund DHS.", "time": "Mar 22, 2026 - 03:29 PM", "timestamp": "Sun Mar 22 15:29:11 +0000 2026", "foot": "@JDVance"}, {"platform": "X / Twitter", "handle": "@JDVance", "url": "https://x.com/JDVance/status/2034325552555770150", "icon": "<svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"/></svg>", "text": "Americans deserve to have their voices heard, and that starts with safe and secure elections. Pass the Save America Act NOW.", "time": "Mar 18, 2026 - 05:46 PM", "timestamp": "Wed Mar 18 17:46:22 +0000 2026", "foot": "@JDVance"}, {"platform": "X / Twitter", "handle": "@JDVance", "url": "https://x.com/JDVance/status/2034014553172857219", "icon": "<svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"/></svg>", "text": "Usha and I were honored to host Ireland&#x27;s Taoiseach @MichealMartinTD and his wife at the Naval Observatory today. \n\nHappy St. Patrick&#x27;s Day!", "time": "Mar 17, 2026 - 09:10 PM", "timestamp": "Tue Mar 17 21:10:34 +0000 2026", "foot": "@JDVance"}, {"platform": "X / Twitter", "handle": "@JDVance", "url": "https://x.com/JDVance/status/2033669928738230451", "icon": "<svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"/></svg>", "text": "It is a disgrace that American children and families are being defrauded by people who hate this country. \n\nI&#x27;m proud to lead the Administration&#x27;s task force on fraud and I&#x27;m thankful to President Trump for entrusting this task to me.", "time": "Mar 16, 2026 - 10:21 PM", "timestamp": "Mon Mar 16 22:21:09 +0000 2026", "foot": "@JDVance"}, {"platform": "X / Twitter", "handle": "@JDVance", "url": "https://x.com/JDVance/statu